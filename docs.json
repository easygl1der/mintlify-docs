{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Yitwah Notes",
  "logo": {
    "light": "/images/logo.svg",
    "dark": "/images/logo.svg"
  },
  "favicon": "/images/favicon.svg",
  "colors": {
    "primary": "#16A34A",
    "light": "#07C983",
    "dark": "#15803D"
  },
  "navigation": {
    "tabs": [
      {
        "tab": "文档",
        "groups": [
          {
            "group": "入门",
            "pages": ["index", "quickstart"]
          },
          {
            "group": "概念",
            "pages": ["concepts/overview", "concepts/knowledge-management", "concepts/markdown-best-practices"]
          },
          {
            "group": "实践指南",
            "pages": ["how-to/organize-notes", "how-to/deploy-with-mintlify"]
          },
          {
            "group": "代码片段",
            "pages": ["snippets/useful-commands", "snippets/mdx-examples"]
          }
        ]
      }
    ]
  },
  "footer": {
    "socials": {
      "github": "https://github.com/easygl1der"
    }
  },
  "contextual": {
    "options": ["copy", "view", "claude"]
  }
}
